# BlackTenderscore MCP — Configuration
# Copier en .env et remplir les valeurs

# URL du site WordPress (sans slash final)
WORDPRESS_URL=https://ton-site.com

# Credentials WordPress Application Password
# Format: base64("username:xxxx xxxx xxxx xxxx xxxx xxxx")
# Générer : Settings > Users > Application Passwords dans WP admin
# Encoder : echo -n "admin:abcd 1234 efgh 5678" | base64
WORDPRESS_AUTH=dXNlcjpwYXNzd29yZA==
